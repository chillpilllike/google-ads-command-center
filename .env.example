# Copy this file to .env and fill only deployment/runtime values locally.
# Google OAuth refresh tokens and API credentials are stored in Postgres from the
# Settings / Analytics connection pages, not in this file.
APP_NAME="Google Ads Command Center"
APP_ENV=local
APP_INSTANCE_ROLE=developer
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgres://postgres:postgres@localhost:5432/google_ads_command_center
POSTGRES_URL=
AUTO_INIT_DB=false
ADMIN_EMAIL=admin
ADMIN_PASSWORD=change-this-before-production

# Container runtime. Local/developer instances keep the worker and scheduler off
# so the production server remains the only live Google Ads automation writer.
PORT=8000
WEB_CONCURRENCY=1
INIT_DRAMATIQ_SCHEMA=true
INIT_APP_DB=true
DRAMATIQ_ENABLED=false
DRAMATIQ_PROCESSES=1
DRAMATIQ_THREADS=2
SCHEDULER_ENABLED=false
AUTOMATION_SCHEDULER_INTERVAL_SECONDS=900
AUTOMATION_SCHEDULER_RECOMPUTE_EVERY_RUNS=4

# Legacy one-time import fallback only. Leave these blank for normal app/worker
# usage; the web app and background workers read saved credentials from Postgres.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# Optional: instead of duplicating credentials here, point to an existing Python
# script that defines GOOGLE_ADS_CONFIG and CUSTOMER_ID. Environment variables
# above override values from the script when both are set.
GOOGLE_ADS_CONFIG_PY=

# Optional. Leave blank to use the default version from the installed google-ads package.
GOOGLE_ADS_API_VERSION=

# Safety controls. Developer instances are forced to dry-run by runtime role
# even if Postgres settings are accidentally enabled for live mutations.
GOOGLE_ADS_ALLOW_MUTATIONS=false
GOOGLE_ADS_DRY_RUN=true
GOOGLE_ADS_CHANGE_COOLDOWN_HOURS=24
GOOGLE_ADS_OPTIMIZATION_DATE_RANGE=LAST_7_DAYS
GOOGLE_ADS_BASELINE_DATE_RANGE=LAST_30_DAYS
GOOGLE_ADS_MIN_CONVERSIONS_FOR_BID_CHANGE=5
GOOGLE_ADS_MIN_COST_FOR_ACTION=25
GOOGLE_ADS_ZERO_CONVERSION_MIN_CLICKS=10
GOOGLE_ADS_MAX_BUDGET_CHANGE_PCT=0.20
GOOGLE_ADS_MAX_TARGET_ROAS_CHANGE_PCT=0.10
GOOGLE_ADS_MIN_DAILY_BUDGET=1
GOOGLE_ADS_ALLOW_TOTAL_BUDGET_INCREASE=false

# Optional reporting and campaign creation toggles.
GOOGLE_ADS_REPORT_DIR=reports
GOOGLE_ADS_STATE_DIR=state
